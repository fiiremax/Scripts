-- Stop Velocity(Sem argumentos = vel0 para meu humanoidrootpart, target = tirar velocidade de outros)
function UModule.SVel(mode, target)
    if target then
        if target:IsA("BasePart") then
            if mode == "Target" then
                target.Velocity = Vector3.zero
                target.RotVelocity = Vector3.zero
                return 
            end
        elseif target:IsA("Model") then
            if mode == "Target" then
                for _, part in ipairs(target:GetDescendants()) do
                    if part:IsA("BasePart") then  
                        part.Velocity = Vector3.zero
                        part.RotVelocity = Vector3.zero
                    end
                end
                return 
            end
        end
    end
    
    local hrp = UModule.env.ov.char:WaitForChild("HumanoidRootPart")
    hrp.AssemblyLinearVelocity = Vector3.zero
end
--Find Item in front (retorna item na mira)
function UModule.FINF()
    local unitRay = UModule.env.ov.cam:ScreenPointToRay(UModule.env.ov.mouse.X, UModule.env.ov.mouse.Y)
    if not unitRay then
        return nil
    end
    
    local ray = Ray.new(unitRay.Origin, unitRay.Direction * 10000)
    local part, position = workspace:FindPartOnRay(ray, UModule.env.ov.char, false, true)
    
    if part and part:IsA("BasePart") and not part:IsDescendantOf(UModule.env.ov.char) then
        return part
    end
    
    return nil
end
-- Is ProtectedPart + P :D (retorna part protegida)
function UModule.IPPP(part, mode)
    local function IPIM(part, model)
        return model and part:IsDescendantOf(model) or false
    end
    
    local function IPWF(folderName)
        local folder = workspace:FindFirstChild(folderName)
        return IPIM(part, folder)
    end
    
    local function IPIGP()
        local gpow = workspace:FindFirstChild("GrabParts")
        if IPIM(part, gpow) then return true end
        
        for _, character in pairs(workspace:GetChildren()) do
            if character:IsA("Model") and character ~= UModule.env.ov.char then
                local gponc = character:FindFirstChild("GrabParts")
                if IPIM(part, gponc) then return true end
            end
        end
        
        return false
    end
    
    local IPt = IPWF("Map")
        or IPWF("Plots")
        or IPWF("Slots")
        or IPIGP()
        or part:IsDescendantOf(UModule.env.ov.char)
    
    if mode == 2 then
        if part:IsDescendantOf(UModule.env.ov.inv) then
            return true
        end
    end
    
    return IPt
end
-- tp (Position)
function UModule.tp(a)
    local h = UModule.MBP("HumanoidRootPart")
    local t = typeof(a) == "Vector3" and a or 
              (a:IsA("Model") and (a:GetPrimaryPartCFrame().Position or 
              a:FindFirstChild("HumanoidRootPart").Position) or a.Position)
    
    if not t then return end
    
    local hum = h.Parent:FindFirstChildOfClass("Humanoid")
    local hipHeight = hum and hum.HipHeight or 0
    local offset = (h.Size.Y / 2) + hipHeight + 3.5
    local currentCF = h.Parent:GetPivot()
    
    h.Parent:PivotTo(CFrame.new(t.X, t.Y + offset, t.Z) * (currentCF - currentCF.Position))
end
-- Spawn Item in CFrame(nome, cframe, front(frente), default)
function UModule.SICF(itemName, cframe, mode)
    task.spawn(function()
        local hrp = UModule.env.ov.char:WaitForChild("HumanoidRootPart")
        local rotation = Vector3.new(0, 0, 0)

        if mode == "Default" then
            local cf = hrp.CFrame
            local spawnCFrame = cf * CFrame.new(5, 8, 25)
            vgs.RS.MenuToys.SpawnToyRemoteFunction:InvokeServer(itemName, spawnCFrame, rotation)
            return
        
        elseif mode == "Front" then
            vgs.RS.MenuToys.SpawnToyRemoteFunction:InvokeServer(
                itemName, 
                hrp.CFrame - (hrp.CFrame.LookVector * 5) - Vector3.new(0, 0, 0), 
                Vector3.new(0, 0, 0)
            )
            return
        end

        vgs.RS.MenuToys.SpawnToyRemoteFunction:InvokeServer(itemName, cframe, rotation)
    end)
end
-- Auto Explicativo (ve se a part eta dentro da radius) 
function UModule.IsAround(part, radius)
    if part:IsA("Model") then
        return (part.PrimaryPart.Position - UModule.MBP("HumanoidRootPart").Position).Magnitude <= radius
    else
        return (part.Position - UModule.MBP("HumanoidRootPart").Position).Magnitude <= radius
    end
end
-- FMC(30)/ FMC(plrs, func, valor)
function UModule.FMC(arg1, arg2, arg3)
    if type(arg1) == "string" and arg1 == "plrs" then
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        for _, player in ipairs(game.Players:GetPlayers()) do
            if player.Character and player ~= game.Players.LocalPlayer then
                local phrp = player.Character:FindFirstChild("HumanoidRootPart")
                if phrp and UModule.IsAround(phrp, arg3 or 29) then
                    if arg2 and type(arg2) == "function" then
                        arg2(player.Character)
                    end
                end
            end
        end
        return
    end
    
    if type(arg1) ~= "number" then
        if not arg1 then return nil end
        local char = arg1:FindFirstAncestorOfClass("Model")
        return char and char:FindFirstChild("Humanoid") 
            and game:GetService("Players"):GetPlayerFromCharacter(char) or nil
    end
    
    local char = game.Players.LocalPlayer.Character
    if not char then return {} end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end
    
    local results, seen = {}, {}
    
    local filter = {char}
    local enames = {"Map", "Plots", "Slots", "GrabParts"}
    
    for _, name in ipairs(enames) do
        local obj = workspace:FindFirstChild(name)
        if obj then table.insert(filter, obj) end
    end
    
    for _, model in ipairs(workspace:GetChildren()) do
        if model:IsA("Model") and model ~= char then
            local gp = model:FindFirstChild("GrabParts")
            if gp then table.insert(filter, gp) end
        end
    end
    
    if arg3 ~= 2 then
        local inv = workspace:FindFirstChild(game.Players.LocalPlayer.Name .. "SpawnedInToys")
        if inv then table.insert(filter, inv) end
    end
    
    local params = OverlapParams.new()
    params.FilterDescendantsInstances = filter
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    local parts = workspace:GetPartBoundsInBox(
        CFrame.new(hrp.Position), 
        Vector3.new(arg1 * 2, arg1 * 2, arg1 * 2), 
        params
    )
    
    for _, part in ipairs(parts) do
        if not UModule.IPPP(part, arg3) then
            local model = part:FindFirstAncestorOfClass("Model")
            
            if arg2 then
                if model and arg2(model) and not seen[model] then
                    seen[model] = true
                    table.insert(results, model)
                end
            else
                if model and not seen[model] then
                    seen[model] = true
                    table.insert(results, model)
                elseif not model and not seen[part] then
                    seen[part] = true
                    table.insert(results, part)
                end
            end
        end
    end
    
    return results
end
-- var() gerenciador de variaveis
function UModule.var(a1, a2, a3)
    if type(a1) == "table" and a2 == nil then
        for k, v in pairs(a1) do
            UModule.env[k] = v
        end
        return true
    end
    
    if type(a1) == "string" and a2 == nil and a3 == nil then
        local vN = tostring(a1)
        
        function ST(tbl, key, visited)
            visited = visited or {}
            if visited[tbl] then return nil end
            visited[tbl] = true
            
            if type(tbl) == "table" then
                if tbl[key] ~= nil then
                    return tbl[key]
                end
                
                for k, v in pairs(tbl) do
                    if type(v) == "table" and k ~= "Conns" and k ~= "Connections" and k ~= "ov" then
                        local result = ST(v, key, visited)
                        if result ~= nil then
                            return result
                        end
                    end
                end
            end
            
            return nil
        end
        
        return ST(UModule.env, vN)
    end
    
    if type(a1) == "string" and a2 ~= nil then
        if a3 ~= nil then
            if not UModule.env[a1] then
                UModule.env[a1] = {}
            end
            if type(UModule.env[a1]) ~= "table" then
                UModule.env[a1] = {}
            end
            UModule.env[a1][a2] = a3
            return true
        else
            UModule.env[a1] = a2
            return true
        end
    end
    
    return nil
end

getgenv().var = UModule.var

UModule.tm = {}
-- gerenciador de tabela
function UModule.tm.Add(tbl, key, value)
    if type(tbl) ~= "table" then
        return false
    end
    
    if key == nil then
        return false
    end
    
    if value ~= nil then
        tbl[key] = value
    else
        local exists = false
        for _, v in pairs(tbl) do
            if v == key then
                exists = true
                break
            end
        end
        
        if not exists then
            table.insert(tbl, key)
        end
    end
    
    return true
end

function UModule.tm.Find(tbl, key)
    if type(tbl) ~= "table" then
        return nil
    end
    
    if key == nil then
        return nil
    end
    
    if tbl[key] ~= nil then
        return tbl[key]
    end
    
    for i, v in pairs(tbl) do
        if v == key then
            return i, v
        end
    end
    
    return nil
end

function UModule.tm.val(tbl, key)
    if type(tbl) ~= "table" then
        return false
    end
    
    if key == nil then
        return false
    end
    
    local value = tbl[key]
    
    if value == nil then
        for _, v in pairs(tbl) do
            if v == key then
                return true
            end
        end
        return false
    end
    
    if type(value) == "boolean" then
        return value
    end
    
    if value ~= nil and value ~= false then
        return true
    end
    
    return false
end

function UModule.tm.Remove(tbl, key)
    if type(tbl) ~= "table" then
        return false
    end
    
    if key == nil then
        return false
    end
    
    if tbl[key] ~= nil then
        tbl[key] = nil
        return true
    end
    
    for i, v in pairs(tbl) do
        if v == key then
            if type(i) == "number" then
                table.remove(tbl, i)
            else
                tbl[i] = nil
            end
            return true
        end
    end
    
    return false
end

function UModule.tm.Clear(tbl)
    if type(tbl) ~= "table" then
        return false
    end
    
    for k in pairs(tbl) do
        tbl[k] = nil
    end
    
    return true
end
-- gerenciador de conecçoes(part, conn, func, nome)// conceçoes(part, PropertyChanged, val, func, nome)
function UModule.cm(arg1, arg2, arg3, arg4, arg5)
    if type(arg1) == "string" and arg2 == "disc" then
        local connName = arg1
        if UModule.env.Connections[connName] then
            pcall(function()
                UModule.env.Connections[connName]:Disconnect()
            end)
            UModule.env.Connections[connName] = nil
        end
        return
    end
    
    local instance = arg1
    local eventType = arg2
    local callback, propName, connName
    
    function gfuncst(func)
        local info = debug.getinfo(func, "S")
        if info and info.source and info.linedefined then
            local source = info.source
            if source:sub(1, 1) == "@" then
                source = source:sub(2)
            end
            return source .. ":" .. info.linedefined .. "-" .. info.lastlinedefined
        end
        return tostring(func)
    end
    
    if type(arg2) == "function" then
        callback = arg2
        connName = arg3
        
        if not connName then
            connName = tostring(instance) .. "_Destroying_" .. gfuncst(callback)
        end
        
        if UModule.env.Connections[connName] then
            UModule.env.Connections[connName] = nil
        end
        
        local connection = instance.Destroying:Connect(function()
            callback()
        end)
        
        UModule.env.Connections[connName] = {
            connection = connection,
            instance = instance,
            eventType = "Destroying",
            _callback = callback,
            _funcString = gfuncst(callback),
            Disconnect = function(self)
                if self.connection then
                    pcall(function()
                        self.connection:Disconnect()
                    end)
                    self.connection = nil
                    UModule.env.Connections[connName] = nil
                end
            end
        }
        
        return UModule.env.Connections[connName]
    end
    
    if type(eventType) == "string" and (eventType == "PropertyChanged" or eventType:match("^GetPropertyChangedSignal")) then
        propName = arg3
        callback = arg4
        connName = arg5
        
        if not propName or not callback then
            warn("PropertyChanged requer o nome da propriedade e uma funçao callback")
            return
        end
    else
        callback = arg3
        connName = arg4
    end
    
    if not instance or not eventType or not callback then
        return
    end
    
    local funcString = gfuncst(callback)
    
    if not connName then
        if propName then
            connName = tostring(instance) .. "_" .. tostring(eventType) .. "_" .. propName .. "_" .. funcString
        else
            connName = tostring(instance) .. "_" .. tostring(eventType) .. "_" .. funcString
        end
    end
    
    if UModule.env.Connections[connName] then
        local existingConn = UModule.env.Connections[connName]
        if existingConn._funcString == funcString then
            UModule.env.Connections[connName] = nil
        else
            connName = connName .. "_" .. tick()
        end
    end
    
    local connection
    local success, err = pcall(function()
        if eventType == "PropertyChanged" then
            connection = instance:GetPropertyChangedSignal(propName):Connect(callback)
        else
            local event = instance[eventType]
            if event and typeof(event) == "RBXScriptSignal" then
                connection = event:Connect(callback)
            else
                error("Evento '" .. eventType .. "' nao encontrado em " .. tostring(instance))
            end
        end
    end)
    
    if not success then
        warn("Erro ao criar conexao: " .. tostring(err))
        return
    end
    
    task.spawn(function()
        instance.Destroying:Connect(function()
            if connection then
                connection:Disconnect()
                connection = nil
                if UModule.env.Connections[connName] then
                    UModule.env.Connections[connName] = nil
                end
            end
        end)
    end)
    
    UModule.env.Connections[connName] = {
        connection = connection,
        instance = instance,
        eventType = eventType,
        propName = propName,
        _callback = callback,
        _funcString = funcString,
        Disconnect = function(self)
            if self.connection then
                pcall(function()
                    self.connection:Disconnect()
                end)
                self.connection = nil
                UModule.env.Connections[connName] = nil
            end
        end
    }
    
    return UModule.env.Connections[connName]
end

return UModule
