-- Retorna lista com nome e diplay nome (Dropdown)
function UModule.GPNames(mode, arg)
    local pnames = {}
    if mode == "func" then
        for _, p in pairs(vgs.ps:GetPlayers()) do
            if p ~= vgs.p and not arg() then
                table.insert(pnames, p.Name .. " (" .. p.DisplayName .. ")")
